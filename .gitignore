node_modules/
*.log
Thumbs.db
.DS_Store

# Deploy secrets and generated snapshot (contains real member PII) — never commit
App/deploy/secrets.php
App/deploy/_data.html

# FTP credentials for deploy/ftp-deploy.sh, read at runtime by that script — same
# pattern as ../BusinessWebExpress/.ftp-credentials. Never committed. Create your
# own copy from .ftp-credentials.example (which IS committed, as a template).
App/deploy/.ftp-credentials

# Sponsor list, uploaded registrations, and the imported member roster accumulate
# live on the server — never committed, and never overwritten by a deploy (see
# deploy/ftp-deploy.sh, which deliberately doesn't upload any of them)
App/deploy/sponsor-submissions.json
App/deploy/registrations-data.json
App/deploy/members-data.json
App/deploy/password-reset.json
